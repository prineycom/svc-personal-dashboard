# Env vars this service needs. Document NAMES here; set REAL values in
# Dokploy → Environment. Never commit real secrets.
# (For local testing you may copy this to .env — which is gitignored.)

# --- routing (required: consumed by the Traefik labels in docker-compose.yml) ---
SERVICE_DOMAIN=app.example.com   # the host this service answers on
SERVICE_NAME=my-service          # unique Traefik router id on the machine (letters/digits/-)

# --- non-secret config ---
EXAMPLE_VAR=changeme

# --- secrets: set in Dokploy, leave blank/absent here ---
# SECRET_TOKEN=
# POSTGRES_USER=app
# POSTGRES_DB=app
# POSTGRES_PASSWORD=
