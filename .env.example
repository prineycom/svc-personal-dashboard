# ── Personal Dashboard — ALL environment variables ─────────────────────
# Copy this file to .env (gitignored) for local runs, OR paste the whole
# block into Dokploy → Environment for a deployment.
#
# Every value below is a MOCK placeholder — replace secrets with real,
# randomly generated values. Never commit real secrets.
#   - passwords / secrets:  openssl rand -base64 32
#   - wger 50-char keys:    python -c "import secrets; print(secrets.token_urlsafe(50))"
#   - firefly APP_KEY:      echo "base64:$(openssl rand -base64 32)"

# ── Compose project name ────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=pd

# ── PostgreSQL (shared) ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-postgres-password
# Publish raw TCP only if you really need external DB access (then use a
# strong password + fail2ban). Leave empty to keep PostgreSQL private.
DB_PUBLIC_PORT=

# ── Vikunja (Tasks) ───────────────────────────────────────────────────────
VIKUNJA_DATABASE_TYPE=postgres
VIKUNJA_DATABASE_HOST=postgres
VIKUNJA_DATABASE_USER=postgres
VIKUNJA_DATABASE_PASSWORD=change-me-strong-postgres-password
VIKUNJA_DATABASE_DATABASE=vikunja
VIKUNJA_SERVICE_SECRET=change-me-vikunja-secret-64-hex-chars-0000000000000000000000
# MUST match the public domain, or the frontend calls the wrong API host.
VIKUNJA_SERVICE_PUBLICURL=http://tasks.example.com
VIKUNJA_PORT=3456

# ── Firefly III (Finances) ────────────────────────────────────────────────
FIREFLY_APP_ENV=production
FIREFLY_APP_DEBUG=false
FIREFLY_SITE_OWNER=owner@example.com
FIREFLY_APP_KEY=base64:ChangeMeChangeMeChangeMeChangeMeChangeMe01=
#   👆 Must be "base64:<32 random bytes>" — echo "base64:$(openssl rand -base64 32)"
FIREFLY_DEFAULT_LANGUAGE=ru_RU
FIREFLY_DEFAULT_LOCALE=ru_RU
FIREFLY_TZ=Europe/Belgrade
FIREFLY_LOG_CHANNEL=stack
FIREFLY_APP_LOG_LEVEL=notice
FIREFLY_DB_CONNECTION=pgsql
FIREFLY_DB_HOST=postgres
FIREFLY_DB_PORT=5432
FIREFLY_DB_DATABASE=firefly
FIREFLY_DB_USERNAME=postgres
FIREFLY_DB_PASSWORD=change-me-strong-postgres-password
FIREFLY_STATIC_CRON_TOKEN=change-me-32-char-cron-token-0000
# MUST match the public domain.
FIREFLY_APP_URL=http://finance.example.com
FIREFLY_PORT=8080

# ── Wger (Health/Fitness) ────────────────────────────────────────────────
WGER_PORT=8001
WGER_SECRET_KEY=change-me-wger-secret-key-50-random-chars-aaaaaaaa
WGER_SIGNING_KEY=change-me-wger-signing-key-50-random-chars-bbbbbbbb
# MUST be "False" so the entrypoint runs collectstatic (else /static/ = 404).
WGER_DJANGO_DEBUG=False
# MUST match the public domain, or login returns 403.
WGER_CSRF_TRUSTED_ORIGINS=http://fitness.example.com
WGER_TIME_ZONE=Europe/Belgrade
WGER_TZ=Europe/Belgrade
WGER_INSTANCE=https://wger.de
WGER_ALLOW_REGISTRATION=True
WGER_ALLOW_GUEST_USERS=False
WGER_ALLOW_UPLOAD_VIDEOS=True
WGER_MIN_ACCOUNT_AGE_TO_TRUST=21
WGER_SYNC_EXERCISES_CELERY=True
WGER_SYNC_EXERCISE_IMAGES_CELERY=True
WGER_SYNC_EXERCISE_VIDEOS_CELERY=True
WGER_SYNC_INGREDIENTS_CELERY=True
WGER_SYNC_INGREDIENTS_DUMP_URL=https://wger.de/media/ingredients/ingredients.jsonl.gz
WGER_DOWNLOAD_INGREDIENTS_FROM=WGER
WGER_CACHE_API_EXERCISES_CELERY=True
WGER_CACHE_API_EXERCISES_CELERY_FORCE_UPDATE=True
WGER_USE_CELERY=True
WGER_CELERY_BROKER=redis://redis:6379/2
WGER_CELERY_BACKEND=redis://redis:6379/2
WGER_CELERY_FLOWER_PASSWORD=change-me-flower-password
WGER_DJANGO_DB_ENGINE=django.db.backends.postgresql
WGER_DJANGO_DB_DATABASE=wger
WGER_DJANGO_DB_USER=postgres
WGER_DJANGO_DB_PASSWORD=change-me-strong-postgres-password
WGER_DJANGO_DB_HOST=postgres
WGER_DJANGO_DB_PORT=5432
WGER_DJANGO_PERFORM_MIGRATIONS=True
WGER_DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
WGER_DJANGO_CACHE_LOCATION=redis://redis:6379/1
WGER_DJANGO_CACHE_CLIENT_CLASS=django_redis.client.DefaultClient
WGER_DJANGO_CACHE_TIMEOUT=12960

# ── Linkding (Bookmarks) ──────────────────────────────────────────────────
# MUST match the public domain, or login returns 403.
LD_CSRF_TRUSTED_ORIGINS=http://bookmarks.example.com
# Linkding has no signup page — set these to auto-create the first superuser
# on startup. Leave empty to create users manually instead.
LD_SUPERUSER_NAME=admin
LD_SUPERUSER_PASSWORD=change-me-linkding-password
LINKDING_PORT=9090

# ── BeaverHabits (Habits) ─────────────────────────────────────────────────
BEAVERHABITS_PORT=8081

# ── OpenTickly (Time Tracker) ────────────────────────────────────────────
OPENTICKLY_PORT=8082

# ── MCP layer (stage 2) ───────────────────────────────────────────────────
# One MCP server per direction, reachable by Hermes over HTTP behind
# mcp-<svc>.dashboard.example.com (network protection is Tailscale).
# These are SERVICE API tokens the MCP uses to call its service — generate
# each in the service's own UI. Convention: <SERVICE>_MCP_TOKEN, mapped in
# docker-compose.yml to whatever env var the MCP image expects.
# See docs/mcp/CONVENTIONS.md and docs/adr/0007-mcp-integration-topology.md.
#
# Full Vikunja MCP setup: services/_mcp/README.md → "Vikunja MCP — setup".
#
# mcp-vikunja (REQUIRED for the bridge to authenticate):
#   Vikunja API token — Vikunja UI → Settings → API Tokens → Create.
#   Format: starts with `tk_` (e.g. tk_abc123…). Grant tasks/projects/labels
#   read+write. Mapped to VIKUNJA_API_TOKEN in docker-compose.yml.
#   (The service URL VIKUNJA_URL=http://vikunja:3456/api/v1 is fixed in
#    docker-compose.yml — the /api/v1 suffix is mandatory.)
#
# Firefly III MCP — настройка по шагам: docs/mcp/firefly-iii.md
#   REQUIRED: FIREFLY_MCP_TOKEN  — Firefly Personal Access Token
#             (Firefly UI → ⚙ Options → Profile → вкладка OAuth →
#              Personal Access Tokens → Create new token; токен виден один раз).
#   OPTIONAL: FIREFLY_MCP_PORT   — host-порт только для локального теста
#             (на Dokploy оставить пустым). FIREFLY_URL прописан в compose
#             как http://firefly-app:8080 и в .env не выносится.
VIKUNJA_MCP_TOKEN=
FIREFLY_MCP_TOKEN=
WGER_MCP_TOKEN=
LINKDING_MCP_TOKEN=
BEAVERHABITS_MCP_TOKEN=
OPENTICKLY_MCP_TOKEN=
# Host-published ports for the MCP servers.
# Hermes runs on the same Pi, so it reaches each MCP at http://127.0.0.1:<port>/mcp
# — a fixed port is the simplest, most reliable transport (no DNS/Traefik/TLS).
# Pin a fixed, FREE port per service. An EMPTY value publishes container port
# 8000 to a RANDOM host port that changes on every redeploy (don't do that).
# In use already: 80 443 3000 3456 4000 8001 8080 8081 8082 9090 — avoid these.
# Leave empty only if you instead route via an mcp-<svc> subdomain in Dokploy.
VIKUNJA_MCP_PORT=8765
FIREFLY_MCP_PORT=
WGER_MCP_PORT=
LINKDING_MCP_PORT=
BEAVERHABITS_MCP_PORT=
OPENTICKLY_MCP_PORT=
