# ── Personal Dashboard — environment variables ──────────────────────────
# Copy to .env and fill with real values. Never commit .env itself.
# Set these in Dokploy → Environment.

# ── Compose project name ────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=pd

# ── PostgreSQL (shared) ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
# Optional: publish PostgreSQL to host network (e.g. "6432")
# Leave empty to keep DB private on internal network.
DB_PUBLIC_PORT=
