# ── Personal Dashboard — environment variables ──────────────────────────
# Copy to .env and fill with real values. Never commit .env itself.
# Set these in Dokploy → Environment.

# ── Compose project name ────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=pd

# ── PostgreSQL (shared) ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
# Optional: publish PostgreSQL to host network (e.g. "6432")
# Leave empty to keep DB private on internal network.
DB_PUBLIC_PORT=

# ── Vikunja (Tasks) ───────────────────────────────────────────────────────
VIKUNJA_DATABASE_TYPE=postgres
VIKUNJA_DATABASE_HOST=postgres
VIKUNJA_DATABASE_USER=postgres
VIKUNJA_DATABASE_PASSWORD=
VIKUNJA_DATABASE_DATABASE=vikunja
VIKUNJA_SERVICE_SECRET=
VIKUNJA_SERVICE_PUBLICURL=http://localhost:3456
VIKUNJA_PORT=3456

# ── Firefly III (Finances) ────────────────────────────────────────────────
FIREFLY_APP_ENV=production
FIREFLY_APP_DEBUG=false
FIREFLY_SITE_OWNER=
FIREFLY_APP_KEY=
#   👆 Must be in format "base64:<random>" — generate with:
#      echo "base64:$(openssl rand -base64 32)"
FIREFLY_DEFAULT_LANGUAGE=ru_RU
FIREFLY_DEFAULT_LOCALE=ru_RU
FIREFLY_TZ=Europe/Moscow
FIREFLY_LOG_CHANNEL=stack
FIREFLY_APP_LOG_LEVEL=notice
FIREFLY_DB_CONNECTION=pgsql
FIREFLY_DB_HOST=postgres
FIREFLY_DB_PORT=5432
FIREFLY_DB_DATABASE=firefly
FIREFLY_DB_USERNAME=postgres
FIREFLY_DB_PASSWORD=
FIREFLY_STATIC_CRON_TOKEN=
FIREFLY_PORT=8080

# ── Wger (Health/Fitness) ────────────────────────────────────────────────
WGER_PORT=8001

# ── Linkding (Bookmarks) ──────────────────────────────────────────────────
LINKDING_PORT=9090
