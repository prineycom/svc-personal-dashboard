# ── Linkding (Bookmarks) ─────────────────────────────────────────────────
# Uses embedded SQLite — no external DB needed.

# MUST match the public domain, or login (POST) returns 403.
LD_CSRF_TRUSTED_ORIGINS=http://bookmarks.example.com

# Linkding has no signup page — set these to auto-create the first superuser
# on startup. Leave empty to create users manually:
#   docker exec -it <linkding> python manage.py createsuperuser
LD_SUPERUSER_NAME=admin
LD_SUPERUSER_PASSWORD=change-me-linkding-password

# Port for local testing — set in root .env
# LINKDING_PORT=9090
