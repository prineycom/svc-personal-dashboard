# ── Vaultwarden (Passwords) ───────────────────────────────────────────────
# Self-hosted, Bitwarden-compatible. Embedded SQLite — no external DB needed.
# The SQLite db is created automatically in the vaultwarden_data volume.

# MUST match the public domain, or WebAuthn/attachments/admin links break.
VAULTWARDEN_DOMAIN=http://passwords.example.com

# Registration stays open; real protection is Tailscale (no SSO needed).
# Set to false to close signups once your account exists.
VAULTWARDEN_SIGNUPS_ALLOWED=true

# Admin panel token — Argon2 PHC hash. Generate with:
#   docker run --rm -it vaultwarden/server /vaultwarden hash
# Leave empty to disable the /admin panel entirely.
VAULTWARDEN_ADMIN_TOKEN=

# Port for local testing — set in root .env
# VAULTWARDEN_PORT=9100
