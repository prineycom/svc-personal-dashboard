# ── Shared Infrastructure ────────────────────────────────────────────────
# Values for these vars go in Dokploy → Environment. Never commit real values.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
# Optional: publish PostgreSQL to host network (e.g. "6432" for port 6432)
# Leave empty to keep DB private on internal network.
DB_PUBLIC_PORT=
