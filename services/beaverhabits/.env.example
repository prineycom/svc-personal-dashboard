# ── BeaverHabits (Habits) ─────────────────────────────────────────────────
# Uses SQLite — no external DB needed.

# Storage mode: DATABASE (single SQLite) or USER_DISK (json per user)
HABITS_STORAGE=DATABASE

# Optional: lock to single user by email
# HABITS_USER_EMAIL=

# Port for local testing — set in root .env
# BEAVERHABITS_PORT=8081
