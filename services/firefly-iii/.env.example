# ── Firefly III (Finances) ──────────────────────────────────────────────
# Values go in Dokploy → Environment. Never commit real values.

# Application
APP_ENV=production
APP_DEBUG=false
SITE_OWNER=
APP_KEY=
#   👆 Must be in format "base64:<random>" — generate with:
#      echo "base64:$(openssl rand -base64 32)"

# Locale (use ru_RU for Russian, en_US for English)
DEFAULT_LANGUAGE=ru_RU
DEFAULT_LOCALE=ru_RU
TZ=Europe/Moscow

# Reverse proxy — trust all
TRUSTED_PROXIES=**

# Logging
LOG_CHANNEL=stack
APP_LOG_LEVEL=notice

# Database (shared PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=firefly
DB_USERNAME=postgres
DB_PASSWORD=

# Cron token — exactly 32 characters
STATIC_CRON_TOKEN=
