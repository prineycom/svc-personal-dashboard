# ── Firefly III (Finances) ──────────────────────────────────────────────
# Mock values — replace secrets before use. In production these go in the
# root .env / Dokploy as FIREFLY_* (see root .env.example).

# Application
APP_ENV=production
APP_DEBUG=false
SITE_OWNER=owner@example.com
APP_KEY=base64:ChangeMeChangeMeChangeMeChangeMeChangeMe01=
#   👆 Must be in format "base64:<32 random bytes>" — generate with:
#      echo "base64:$(openssl rand -base64 32)"

# Public URL — MUST match the domain.
APP_URL=http://finance.example.com

# Locale (use ru_RU for Russian, en_US for English)
DEFAULT_LANGUAGE=ru_RU
DEFAULT_LOCALE=ru_RU
TZ=Europe/Belgrade

# Reverse proxy — trust all (Traefik sits in front)
TRUSTED_PROXIES=**

# Logging
LOG_CHANNEL=stack
APP_LOG_LEVEL=notice

# Database (shared PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=firefly
DB_USERNAME=postgres
DB_PASSWORD=change-me-strong-postgres-password

# Cron token — exactly 32 characters
STATIC_CRON_TOKEN=change-me-32-char-cron-token-0000
