# ── Wger (Health/Fitness) ───────────────────────────────────────────────
# Values go in Dokploy → Environment. Never commit real values.

# Django secrets — 50 char random strings
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
SIGNING_KEY=

# Timezone
TIME_ZONE=Europe/Moscow
TZ=Europe/Moscow

# Application
WGER_INSTANCE=https://wger.de
ALLOW_REGISTRATION=True
ALLOW_GUEST_USERS=False
ALLOW_UPLOAD_VIDEOS=True
MIN_ACCOUNT_AGE_TO_TRUST=21

# Exercise/ingredient sync — use Celery background jobs
SYNC_EXERCISES_CELERY=True
SYNC_EXERCISE_IMAGES_CELERY=True
SYNC_EXERCISE_VIDEOS_CELERY=True
SYNC_INGREDIENTS_CELERY=True
SYNC_INGREDIENTS_DUMP_URL=https://wger.de/media/ingredients/ingredients.jsonl.gz
DOWNLOAD_INGREDIENTS_FROM=WGER
CACHE_API_EXERCISES_CELERY=True
CACHE_API_EXERCISES_CELERY_FORCE_UPDATE=True
USE_CELERY=True

# Celery (using shared Redis)
CELERY_BROKER=redis://redis:6379/2
CELERY_BACKEND=redis://redis:6379/2
CELERY_FLOWER_PASSWORD=

# Database (shared PostgreSQL)
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_DATABASE=wger
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=postgres
DJANGO_DB_PORT=5432
DJANGO_PERFORM_MIGRATIONS=True

# Cache (shared Redis)
DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
DJANGO_CACHE_LOCATION=redis://redis:6379/1
DJANGO_CACHE_CLIENT_CLASS=django_redis.client.DefaultClient
DJANGO_CACHE_TIMEOUT=12960
