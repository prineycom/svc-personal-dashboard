# ── OpenTickly (Time Tracker) ────────────────────────────────────────────
# Uses shared PostgreSQL (DB: opentickly) and shared Redis (db 3).

# Port for local testing — set in root .env
# OPENTICKLY_PORT=8082

# ── OpenTickly MCP (native FastMCP, #17) ──────────────────────────────────
# MCP server for Hermes. Token + port keys live in the root .env (already in
# the root .env.example): OPENTICKLY_MCP_TOKEN, OPENTICKLY_MCP_PORT.
#
# OPENTICKLY_MCP_TOKEN — OpenTickly (Toggl) API token; mapped in
#   docker-compose.yml to the image's TOGGL_API_TOKEN. Generate in OpenTickly UI.
# OPENTICKLY_MCP_PORT  — local-test host port for the MCP container (empty on
#   Dokploy; subdomain mcp-opentickly.dashboard.example.com -> 8000 set in UI).
#
# Base URL is fixed to the internal upstream http://opentickly:8080 in compose.
